{
  "$schema": "https://schema.railway.com/railway.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm install && npm run expo:static:build && npm run server:build"
  },
  "deploy": {
    "startCommand": "npm run server:prod",
"restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}

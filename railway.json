{
  "$schema": "https://schema.railway.com/railway.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm install && npm run expo:web:build && npm run expo:static:build"
  },
  "deploy": {
    "startCommand": "NODE_ENV=production tsx server/index.ts",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
